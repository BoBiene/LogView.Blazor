@implements IAsyncDisposable
@inject IJSRuntime JS

<div class="lv-surface">
    <div class="lv-toolbar">
        <button type="button" class="lv-button" @onclick="TogglePause">@(IsPaused ? "Resume" : "Pause")</button>
        <button type="button" class="lv-button" @onclick="ToggleFollow">@(Follow ? "Following" : "Follow")</button>
        <button type="button" class="lv-button" @onclick="ToggleWrap">@(WrapLines ? "Wrap on" : "Wrap off")</button>
        @if (_pausedCount > 0)
        {
            <span class="lv-badge">Skipped while paused: @_pausedCount</span>
        }
        @if (ToolbarTemplate is not null)
        {
            @ToolbarTemplate
        }
    </div>

    <div class="lv-tail @(WrapLines ? "lv-wrap" : "lv-nowrap")" @ref="_container">
        <Virtualize TItem="LogTailEntry" Items="_entries" Context="entry">
            @if (entry.IsPauseMarker)
            {
                var pause = entry.PauseMarker!;
                <div class="lv-line lv-line-pause">
                    <span class="lv-line-meta">Paused</span>
                    <span>Skipped @pause.SkippedCount log entries from @pause.StartedAt.ToLocalTime().ToString("HH:mm:ss") to @(pause.EndedAt?.ToLocalTime().ToString("HH:mm:ss") ?? "now")</span>
                </div>
            }
            else if (entry.LogItem is { } item)
            {
                if (RowTemplate is not null)
                {
                    @RowTemplate(item)
                }
                else
                {
                    <div class="lv-line @(item.IsError ? "lv-line-error" : string.Empty)">
                        <span class="lv-line-number">@entry.LineNumber</span>
                        @if (ShowTimestamps && item.Timestamp is not null)
                        {
                            <span class="lv-line-meta">@item.Timestamp.Value.ToLocalTime().ToString("HH:mm:ss")</span>
                        }
                        @if (!string.IsNullOrWhiteSpace(item.Source))
                        {
                            <span class="lv-line-source">@item.Source</span>
                        }
                        <span>@item.Text</span>
                    </div>
                }
            }
        </Virtualize>
    </div>
</div>

@code {
    [Parameter, EditorRequired] public ILogFeed<ConsoleLogItem> Feed { get; set; } = default!;
    [Parameter] public RenderFragment<ConsoleLogItem>? RowTemplate { get; set; }
    [Parameter] public RenderFragment? ToolbarTemplate { get; set; }
    [Parameter] public int MaxBufferSize { get; set; } = 500;
    [Parameter] public bool ShowTimestamps { get; set; } = true;
    [Parameter] public bool WrapLines { get; set; }
    [Parameter] public bool Follow { get; set; } = true;
    [Parameter] public LogSubscriptionRequest SubscriptionRequest { get; set; } = new(100, true);

    private LogTailState _state = new(500);
    private List<LogTailEntry> _entries = [];
    private ElementReference _container;
    private CancellationTokenSource? _cts;
    private Task? _subscriptionTask;
    private bool IsPaused { get; set; }
    private int _pausedCount;
    private IJSObjectReference? _module;
    private ILogFeed<ConsoleLogItem>? _currentFeed;
    private LogSubscriptionRequest? _currentRequest;

    protected override async Task OnParametersSetAsync()
    {
        _state.Resize(MaxBufferSize);
        _entries = _state.Snapshot().ToList();

        if (!ReferenceEquals(_currentFeed, Feed) || _currentRequest != SubscriptionRequest)
        {
            _currentFeed = Feed;
            _currentRequest = SubscriptionRequest;
            await RestartSubscriptionAsync();
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (_module is null)
        {
            _module = await JS.InvokeAsync<IJSObjectReference>("import", "./_content/LogView.Blazor/logView.js");
        }

        if (Follow && _module is not null)
        {
            await _module.InvokeVoidAsync("scrollToBottom", _container);
        }
    }

    private async Task RestartSubscriptionAsync()
    {
        if (_subscriptionTask is not null)
        {
            _cts?.Cancel();
            try { await _subscriptionTask; } catch (OperationCanceledException) { }
        }

        _cts = new CancellationTokenSource();
        _subscriptionTask = SubscribeAsync(_cts.Token);
    }

    private async Task SubscribeAsync(CancellationToken cancellationToken)
    {
        await foreach (var batch in Feed.SubscribeAsync(SubscriptionRequest with { Follow = true }, cancellationToken))
        {
            if (IsPaused)
            {
                _state.Pause(batch);
                _pausedCount += batch.Count;
            }
            else
            {
                _state.AppendLogs(batch);
                _entries = _state.Snapshot().ToList();
                await InvokeAsync(StateHasChanged);
            }
        }
    }

    private void TogglePause()
    {
        IsPaused = !IsPaused;
        if (!IsPaused)
        {
            _state.Resume();
            _entries = _state.Snapshot().ToList();
            _pausedCount = 0;
        }
    }

    private void ToggleFollow() => Follow = !Follow;
    private void ToggleWrap() => WrapLines = !WrapLines;

    public async ValueTask DisposeAsync()
    {
        _cts?.Cancel();
        if (_subscriptionTask is not null)
        {
            try { await _subscriptionTask; } catch (OperationCanceledException) { }
        }

        if (_module is not null)
        {
            await _module.DisposeAsync();
        }

        _cts?.Dispose();
    }
}
